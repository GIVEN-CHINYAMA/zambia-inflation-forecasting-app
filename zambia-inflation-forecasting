        "from sklearn.metrics import mean_squared_error, mean_absolute_error\n",
        "import tensorflow as tf\n",
        "from tensorflow.keras.models import Sequential\n",
        "from tensorflow.keras.layers import LSTM, Dense, Dropout\n",
        "from tensorflow.keras.callbacks import EarlyStopping\n",
        "\n",
        "tf.random.set_seed(42)\n",
        "np.random.seed(42)\n",
        "\n",
        "# --- 1. Reload and prepare data ---\n",
        "df = pd.read_csv('zambia_macro_data.csv', parse_dates=['Year'], index_col='Year')\n",
        "df.columns = ['Inflation', 'USDZMW', 'Copper_USD']\n",
        "df['USDZMW_diff'] = df['USDZMW'].diff()\n",
        "df['Copper_diff'] = df['Copper_USD'].diff()\n",
        "df = df.dropna()\n",
        "\n",
        "# --- 2. Scale all features to [0,1] ---\n",
        "feature_cols = ['Inflation', 'USDZMW_diff', 'Copper_diff']\n",
        "scaler = MinMaxScaler()\n",
        "scaled = scaler.fit_transform(df[feature_cols])\n",
        "scaled_df = pd.DataFrame(scaled, columns=feature_cols, index=df.index)\n",
        "\n",
        "# Separate scaler for target (needed to inverse transform later)\n",
        "target_scaler = MinMaxScaler()\n",
        "target_scaled = target_scaler.fit_transform(df[['Inflation']])\n",
        "\n",
        "# --- 3. Create sliding window sequences (window=3) ---\n",
        "WINDOW = 3\n",
        "\n",
        "def create_sequences(data, target, window):\n",
        "    X, y = [], []\n",
        "    for i in range(window, len(data)):\n",
        "        X.append(data[i-window:i])\n",
        "        y.append(target[i])\n",
        "    return np.array(X), np.array(y)\n",
        "\n",
        "X_all, y_all = create_sequences(scaled, target_scaled, WINDOW)\n",
        "dates = df.index[WINDOW:]\n",
        "\n",
        "# --- 4. Chronological train/test split ---\n",
        "split = len(X_all) - 5\n",
