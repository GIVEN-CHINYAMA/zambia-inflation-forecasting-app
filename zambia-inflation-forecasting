        "## Phase 2A: ARIMAX Model (ARIMA with Exogenous Variables)\n",
        "\n",
        "Since Inflation is already stationary (d=0), we use ARIMAX — ARIMA extended\n",
        "with external regressors (exchange rate + copper prices). Auto-ARIMA will\n",
        "find the optimal p and q parameters using AIC. We difference the exogenous\n",
        "variables to make them stationary before passing them in."
      ],
      "metadata": {
        "id": "a7WfXgQs8Uw_"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import pandas as pd\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "from pmdarima import auto_arima\n",
        "from sklearn.metrics import mean_squared_error, mean_absolute_error\n",
        "\n",
        "# --- 1. Reload data ---\n",
        "df = pd.read_csv('zambia_macro_data.csv', parse_dates=['Year'], index_col='Year')\n",
        "df.columns = ['Inflation', 'USDZMW', 'Copper_USD']\n",
        "\n",
        "# --- 2. Difference exogenous variables to make them stationary ---\n",
        "exog = pd.DataFrame({\n",
        "    'USDZMW_diff':     df['USDZMW'].diff(),\n",
        "    'Copper_USD_diff': df['Copper_USD'].diff()\n",
        "}).dropna()\n",
        "\n",
        "# Align inflation with differenced exog (loses first row)\n",
        "inflation_aligned = df['Inflation'].loc[exog.index]\n",
        "\n",
        "# --- 3. Train/test split ---\n",
        "train_y    = inflation_aligned.iloc[:-5]\n",
        "test_y     = inflation_aligned.iloc[-5:]\n",
        "train_exog = exog.iloc[:-5]\n",
        "test_exog  = exog.iloc[-5:]\n",
        "\n",
        "print(f\"📦 ARIMAX Training: {train_y.index.min().year}–{train_y.index.max().year} ({len(train_y)} years)\")\n",
        "print(f\"📦 ARIMAX Testing:  {test_y.index.min().year}–{test_y.index.max().year} ({len(test_y)} years)\\n\")\n",
        "\n",
        "# --- 4. Auto-ARIMA with exogenous variables ---\n",
        "arimax_model = auto_arima(\n",
        "    train_y,\n",
        "    exogenous=train_exog,\n",
        "    d=0,                   # Inflation is already stationary\n",
        "    start_p=0, start_q=0,\n",
        "    max_p=4,   max_q=4,\n",
        "    seasonal=False,\n",
        "    trace=True,\n",
        "    error_action='ignore',\n",
        "    suppress_warnings=True,\n",
        "    stepwise=True\n",
        ")\n",
        "\n",
        "print(f\"\\n🏆 Best ARIMAX Order: {arimax_model.order}\")\n",
        "\n",
        "# --- 5. Forecast ---\n",
        "forecast_arimax, conf_int = arimax_model.predict(\n",
        "    n_periods=5,\n",
        "    exogenous=test_exog,\n",
        "    return_conf_int=True\n",
        ")\n",
        "\n",
        "# --- 6. Metrics ---\n",
        "arimax_rmse = np.sqrt(mean_squared_error(test_y, forecast_arimax))\n",
        "arimax_mae  = mean_absolute_error(test_y, forecast_arimax)\n",
        "arimax_mape = np.mean(np.abs((test_y.values - forecast_arimax) / test_y.values)) * 100\n",
        "\n",
        "print(\"\\n📊 ARIMAX Performance:\")\n",
        "print(f\"   RMSE : {arimax_rmse:.4f}\")\n",
        "print(f\"   MAE  : {arimax_mae:.4f}\")\n",
        "print(f\"   MAPE : {arimax_mape:.2f}%\")\n",
        "\n",
        "# --- 7. Plot ---\n",
        "plt.figure(figsize=(13, 5))\n",
        "plt.plot(train_y.index, train_y, label='Training Data', color='#1f77b4', linewidth=2)\n",
        "plt.plot(test_y.index,  test_y,  label='Actual (Test)', color='#2ca02c', marker='o', linewidth=2)\n",
        "plt.plot(test_y.index,  forecast_arimax, label='ARIMAX Forecast',\n",
        "         color='#d62728', linestyle='--', marker='x', linewidth=2)\n",
        "plt.fill_between(test_y.index, conf_int[:, 0], conf_int[:, 1],\n",
        "                 color='#d62728', alpha=0.15, label='95% Confidence Interval')\n",
        "plt.title('Zambia Inflation — ARIMAX Forecast', fontsize=14, fontweight='bold')\n",
        "plt.xlabel('Year'); plt.ylabel('Inflation (%)')\n",
        "plt.legend(); plt.grid(True, linestyle=':', alpha=0.6)\n",
        "plt.tight_layout()\n",
        "plt.savefig('arimax_forecast.png', dpi=150, bbox_inches='tight')\n",
        "plt.show()\n",
        "\n",
        "# --- 8. Save results for final comparison ---\n",
        "arimax_results = {\n",
        "    'model': 'ARIMAX',\n",
        "    'rmse': arimax_rmse,\n",
        "    'mae': arimax_mae,\n",
        "    'mape': arimax_mape,\n",
        "    'forecast': forecast_arimax,\n",
        "    'actual': test_y.values\n",
        "}\n",
        "print(\"\\n✅ ARIMAX complete — results saved for benchmarking\")"
      ],
