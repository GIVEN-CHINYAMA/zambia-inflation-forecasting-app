        "## Phase 0: Data Collection (v2 — Fixed Exchange Rate Source)\n",
        "We pull data from three sources:\n",
        "- **World Bank API** → Zambia annual inflation (CPI)\n",
        "- **World Bank API** → USD/ZMW exchange rate (PA.NUS.FCRF) ← fixed\n",
        "- **Yahoo Finance** → Copper spot prices (HG=F)"
      ],
      "metadata": {
        "id": "2unrjb3Jds5J"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import wbgapi as wb\n",
        "import yfinance as yf\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "\n",
        "# --- 1. ZAMBIA INFLATION (World Bank) ---\n",
        "infl_raw = wb.data.DataFrame('FP.CPI.TOTL.ZG', 'ZMB', mrv=40)\n",
        "infl = infl_raw.T\n",
        "infl.index = pd.to_datetime(\n",
        "    [str(y) for y in infl.index.str.replace('YR', '')], format='%Y'\n",
        ")\n",
        "infl.columns = ['Inflation']\n",
        "infl = infl.sort_index()\n",
        "print(f\"✅ Inflation: {len(infl)} years | {infl.index.min().year}–{infl.index.max().year}\")\n",
        "\n",
        "# --- 2. USD/ZMW EXCHANGE RATE (World Bank — much longer history) ---\n",
        "# Indicator PA.NUS.FCRF = Official exchange rate (LCU per US$, period average)\n",
        "fx_raw = wb.data.DataFrame('PA.NUS.FCRF', 'ZMB', mrv=40)\n",
        "fx = fx_raw.T\n",
        "fx.index = pd.to_datetime(\n",
        "    [str(y) for y in fx.index.str.replace('YR', '')], format='%Y'\n",
        ")\n",
        "fx.columns = ['USDZMW']\n",
        "fx = fx.sort_index()\n",
        "print(f\"✅ Exchange Rate: {len(fx)} years | {fx.index.min().year}–{fx.index.max().year}\")\n",
        "\n",
        "# --- 3. COPPER PRICES (Yahoo Finance) ---\n",
        "copper = yf.download('HG=F', start='1990-01-01', interval='1mo', auto_adjust=True)['Close']\n",
        "copper = copper.resample('YE').mean()\n",
        "copper.index = copper.index.to_period('Y').to_timestamp()\n",
        "copper.name = 'Copper_USD'\n",
        "print(f\"✅ Copper Prices: {len(copper)} years | {copper.index.min().year}–{copper.index.max().year}\")\n",
        "\n",
        "# --- 4. MERGE ALL SOURCES ---\n",
        "df = infl.join(fx, how='inner').join(copper, how='inner')\n",
        "df.dropna(inplace=True)\n",
        "df.index.name = 'Year'\n",
        "\n",
        "print(f\"\\n📦 Final merged dataset: {df.shape[0]} rows × {df.shape[1]} columns\")\n",
        "print(df.tail(8))\n",
        "\n",
        "# --- 5. SAVE ---\n",
        "df.to_csv('zambia_macro_data.csv')\n",
        "print(\"\\n✅ Saved to zambia_macro_data.csv\")"
      ],
