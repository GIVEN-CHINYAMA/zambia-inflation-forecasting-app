        "print(f\"📦 LSTM Training: {dates[:split].min().year}–{dates[:split].max().year} ({split} years)\")\n",
        "print(f\"📦 LSTM Testing:  {dates[split:].min().year}–{dates[split:].max().year} (5 years)\\n\")\n",
        "\n",
        "# --- 5. Build LSTM model ---\n",
        "model = Sequential([\n",
        "    LSTM(64, return_sequences=True, input_shape=(WINDOW, X_train.shape[2])),\n",
        "    Dropout(0.2),\n",
        "    LSTM(32, return_sequences=False),\n",
        "    Dropout(0.2),\n",
        "    Dense(16, activation='relu'),\n",
        "    Dense(1)\n",
