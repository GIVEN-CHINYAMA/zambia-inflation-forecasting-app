        "## Phase 4: 3-Year Forward Forecast (2025–2027)\n",
        "\n",
        "Using ARIMAX — our best performing model — we generate a forward-looking\n",
        "forecast for Zambia's inflation from 2025 to 2027, with 95% confidence\n",
        "intervals. For the exogenous variables, we use the 3-year rolling mean\n",
        "as a baseline projection."
      ],
      "metadata": {
        "id": "P-WpROddBjpi"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import pandas as pd\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "from pmdarima import auto_arima\n",
        "\n",
        "# --- 1. Reload full data ---\n",
        "df = pd.read_csv('zambia_macro_data.csv', parse_dates=['Year'], index_col='Year')\n",
        "df.columns = ['Inflation', 'USDZMW', 'Copper_USD']\n",
        "df['USDZMW_diff'] = df['USDZMW'].diff()\n",
        "df['Copper_diff'] = df['Copper_USD'].diff()\n",
        "df = df.dropna()\n",
        "exog = df[['USDZMW_diff', 'Copper_diff']]\n",
        "\n",
        "# --- 2. Retrain ARIMAX on FULL dataset ---\n",
        "final_model = auto_arima(\n",
        "    df['Inflation'],\n",
        "    exogenous=exog,\n",
        "    d=0,\n",
        "    start_p=0, start_q=0,\n",
        "    max_p=4,   max_q=4,\n",
        "    seasonal=False,\n",
        "    error_action='ignore',\n",
        "    suppress_warnings=True,\n",
        "    stepwise=True\n",
        ")\n",
        "print(f\"✅ Final model order: {final_model.order}\")\n",
        "\n",
        "# --- 3. Project exogenous variables forward ---\n",
        "future_exog = pd.DataFrame({\n",
        "    'USDZMW_diff': [exog['USDZMW_diff'].tail(3).mean()] * 3,\n",
        "    'Copper_diff': [exog['Copper_diff'].tail(3).mean()] * 3\n",
        "})\n",
        "\n",
        "# --- 4. Forecast 2025–2027 ---\n",
        "future_years = pd.date_range('2025', periods=3, freq='YS')\n",
        "forecast_future, conf_int = final_model.predict(\n",
        "    n_periods=3,\n",
        "    exogenous=future_exog,\n",
        "    return_conf_int=True\n",
        ")\n",
        "\n",
        "print(\"\\n📅 3-Year Inflation Forecast for Zambia:\")\n",
        "print(\"-\" * 45)\n",
        "for year, fc, ci in zip(future_years, forecast_future, conf_int):\n",
        "    print(f\"  {year.year}: {fc:.2f}%  (95% CI: {ci[0]:.2f}% – {ci[1]:.2f}%)\")\n",
        "\n",
        "# --- 5. Plot ---\n",
        "plt.figure(figsize=(13, 6))\n",
        "plt.plot(df.index, df['Inflation'],\n",
        "         label='Historical Inflation', color='#2c3e50',\n",
        "         linewidth=2.5, marker='o', markersize=4)\n",
        "plt.plot(future_years, forecast_future,\n",
        "         label='ARIMAX Forecast (2025–2027)', color='#e74c3c',\n",
        "         linestyle='--', marker='D', linewidth=2.5, markersize=8)\n",
        "plt.fill_between(future_years, conf_int[:, 0], conf_int[:, 1],\n",
        "                 color='#e74c3c', alpha=0.15, label='95% Confidence Interval')\n",
        "plt.axvspan(pd.Timestamp('2024-06-01'), pd.Timestamp('2027-06-01'),\n",
        "            alpha=0.05, color='red', label='Forecast Zone')\n",
