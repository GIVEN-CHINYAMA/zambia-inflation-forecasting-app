        "\n",
        "# --- 7. Forecast ---\n",
        "lstm_forecast_scaled = model.predict(X_test)\n",
        "lstm_forecast = target_scaler.inverse_transform(lstm_forecast_scaled).flatten()\n",
        "actual = target_scaler.inverse_transform(y_test).flatten()\n",
        "\n",
        "# --- 8. Metrics ---\n",
        "lstm_rmse = np.sqrt(mean_squared_error(actual, lstm_forecast))\n",
